# Copia este archivo a .env y configura tu clave válida de Google Gemini
# En desarrollo Vite usará VITE_GOOGLE_API_KEY.
# En producción con el proxy server usa GOOGLE_API_KEY para no exponer la clave en el frontend.
VITE_GOOGLE_API_KEY=your_google_gemini_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
